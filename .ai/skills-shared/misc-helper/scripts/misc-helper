#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: misc-helper <helper>

Helpers:
  davinci-kill        Force-quit DaVinci Resolve app processes if they are stuck.
  cache-clean         Remove known-safe local macOS/app caches and generated assets.
USAGE
}

helper="${1:-}"

case "$helper" in
  cache-clean)
    disk_target="/System/Volumes/Data"
    [[ -d "$disk_target" ]] || disk_target="$HOME"

    available_kib() {
      df -k "$disk_target" | awk 'NR == 2 { print $4 }'
    }

    human_gib_from_kib() {
      awk -v kib="$1" 'BEGIN { printf "%.1f GiB", kib / 1024 / 1024 }'
    }

    echo "This removes local cache/generated-data for apps and dev tools."
    echo "Close affected apps first: Chrome/Google apps, Brave, Vivaldi, Camoufox, Slack, Claude, Insta360 Studio, Cypress/Playwright, and editors using Solargraph/TypeScript."
    echo
    printf "Type CLOSED to confirm those apps are closed and continue: "
    read -r confirmation
    if [[ "$confirmation" != "CLOSED" ]]; then
      echo "Aborted."
      exit 1
    fi

    before_available_kib="$(available_kib)"

    echo
    echo "Disk before cleanup:"
    df -h "$disk_target"

    cleanup_paths=(
      "$HOME/Library/Application Support/Insta360/Insta360 Studio/previewer_cache"
      "$HOME/Library/Application Support/Insta360/Insta360 Studio/log"
      "$HOME/Library/Application Support/com.apple.wallpaper/aerials"
      "$HOME/Library/Application Support/Claude/vm_bundles"
      "$HOME/Library/Application Support/Claude/Cache"
      "$HOME/Library/Caches/Homebrew/downloads"
      "$HOME/Library/Caches/Google"
      "$HOME/Library/Caches/BraveSoftware"
      "$HOME/Library/Caches/com.brave.Browser"
      "$HOME/Library/Caches/camoufox"
      "$HOME/Library/Caches/Vivaldi"
      "$HOME/Library/Caches/Cypress"
      "$HOME/Library/Caches/ms-playwright"
      "$HOME/Library/Caches/typescript"
      "$HOME/Library/Caches/com.tinyspeck.slackmacgap.ShipIt"
      "$HOME/.cache/solargraph"
      "$HOME/.npm/_cacache"
      "$HOME/.yarn/berry/cache"
      "$HOME/.cache/uv"
    )

    echo
    echo "Removing known-safe cache/generated-data paths:"
    removed_paths=()
    missing_paths=()
    for cleanup_path in "${cleanup_paths[@]}"; do
      if [[ -e "$cleanup_path" ]]; then
        du -sh "$cleanup_path" 2>/dev/null || true
        removed_paths+=("$cleanup_path")
      else
        echo "missing: $cleanup_path"
        missing_paths+=("$cleanup_path")
      fi
    done

    rm -rf -- "${cleanup_paths[@]}"

    if command -v brew >/dev/null 2>&1; then
      echo
      echo "Running Homebrew cache cleanup..."
      HOMEBREW_NO_AUTO_UPDATE=1 brew cleanup -s
    else
      echo
      echo "Homebrew not found; skipping brew cleanup."
    fi

    after_available_kib="$(available_kib)"
    freed_kib=$(( after_available_kib - before_available_kib ))

    echo
    echo "Disk after cleanup:"
    df -h "$disk_target"

    echo
    echo "Done. Removed existing cache/generated-data paths:"
    if (( ${#removed_paths[@]} > 0 )); then
      printf '  - %s\n' "${removed_paths[@]}"
    else
      echo "  - none"
    fi
    echo "Approx space freed: $(human_gib_from_kib "$freed_kib")"

    echo
    echo "Manual follow-ups not performed by this helper:"
    echo "  - Codex runtime cache was intentionally skipped while Codex may be running: $HOME/.cache/codex-runtimes"
    echo "  - Telegram: clear local media/cache from Telegram Settings > Data and Storage > Storage Usage."
    echo "  - asdf: review old runtimes with 'asdf list', then remove unused versions with 'asdf uninstall <plugin> <version>'."
    ;;
  davinci-kill)
    readonly resolve_app_path="/Applications/DaVinci Resolve/DaVinci Resolve.app/Contents/MacOS/Resolve"
    readonly ioxpc_app_path="/Applications/DaVinci Resolve/DaVinci Resolve.app/Contents/XPCServices/IOXPC.xpc/Contents/MacOS/IOXPC"

    collect_pids() {
      pgrep -f "^(${resolve_app_path}|${ioxpc_app_path})([[:space:]]|$)" || true
    }

    print_processes() {
      local pid
      for pid in "$@"; do
        ps -p "$pid" -o pid= -o command= || true
      done
    }

    pids=()
    while IFS= read -r pid; do
      [[ -n "$pid" ]] && pids+=("$pid")
    done < <(collect_pids)

    if (( ${#pids[@]} == 0 )); then
      echo "No DaVinci Resolve processes found."
      exit 0
    fi

    echo "Found processes:"
    print_processes "${pids[@]}"

    # Try graceful termination first.
    kill "${pids[@]}" 2>/dev/null || true
    sleep 2

    survivor_pids=()
    while IFS= read -r pid; do
      [[ -n "$pid" ]] && survivor_pids+=("$pid")
    done < <(collect_pids)

    if (( ${#survivor_pids[@]} > 0 )); then
      echo "Still running after SIGTERM; force-killing:"
      print_processes "${survivor_pids[@]}"
      kill -9 "${survivor_pids[@]}" 2>/dev/null || true
      sleep 1
    fi

    remaining_pids=()
    while IFS= read -r pid; do
      [[ -n "$pid" ]] && remaining_pids+=("$pid")
    done < <(collect_pids)

    if (( ${#remaining_pids[@]} > 0 )); then
      echo "Some matching processes remain:"
      print_processes "${remaining_pids[@]}"
      exit 1
    fi

    echo "No matching DaVinci Resolve processes remain."
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    echo "Unknown misc helper: $helper" >&2
    usage >&2
    exit 2
    ;;
esac
