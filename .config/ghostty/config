macos-icon = blueprint
config-file = "~/.dots/themes/active/ghostty"

font-family = "SauceCodePro Nerd Font Mono"
font-family-bold = "Hack Nerd Font"
font-family-italic = "Iosevka Nerd Font Mono"
font-family-bold-italic = "Hack Nerd Font"

font-size = 15
font-thicken = false
adjust-cell-height = 0
adjust-box-thickness = 0

window-decoration = auto
window-padding-x = 10
window-padding-y = 6
window-width = 226
window-height = 64
window-position-x = 128
window-position-y = 73
fullscreen = true
macos-titlebar-style = hidden

minimum-contrast = 1.1

cursor-style = block
cursor-style-blink = false
mouse-hide-while-typing = true

copy-on-select = clipboard
clipboard-paste-protection = true
macos-option-as-alt = true
