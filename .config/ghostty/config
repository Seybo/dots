macos-icon = blueprint
config-file = "~/.dots/themes/active/ghostty"

font-family = "SauceCodePro Nerd Font Mono"
font-family-bold = "Hack Nerd Font"
font-family-italic = "Iosevka Nerd Font Mono"
font-family-bold-italic = "Hack Nerd Font"

font-size = 15
font-thicken = false
adjust-cell-height = 0
adjust-box-thickness = 0

window-decoration = auto
window-padding-x = 10
window-padding-y = 6
window-width = 226
window-height = 64
window-position-x = 128
window-position-y = 73
fullscreen = true
macos-titlebar-style = hidden

minimum-contrast = 1.1

cursor-style = block
cursor-style-blink = false
mouse-hide-while-typing = true

copy-on-select = clipboard
clipboard-paste-protection = true
macos-option-as-alt = true
quit-after-last-window-closed = true

# Zellij tabs
# cmd+t => enter tab mode
keybind = cmd+t=text:

# Zellij sessions
# cmd+s => enter session mode
keybind = cmd+s=text:

# Zellij panes
# cmd+p => enter pane mode
keybind = cmd+p=text:

# Zellij search
# cmd+/ => enter search mode
keybind = cmd+slash=text:

# Zellij scroll
# cmd+; => enter scroll mode
keybind = cmd+semicolon=text:

# Zellij pane navigation
# cmd+h/j/k/l => move focus left/down/up/right
keybind = cmd+h=text:
keybind = cmd+j=text:
keybind = cmd+k=text:
keybind = cmd+l=text:

# Zellij direct session switch
# cmd+1 => switch to system session
keybind = cmd+1=text:󰎤
# cmd+0 => switch to last session
keybind = cmd+0=text:󰎠

