#!/bin/zsh
set -eu

poll_seconds=5
label="local.monit"
repo_dir="${STOW_DIR:-$HOME/.dots}"
source_dir="$repo_dir/no_stow/monit"
runtime_dir="$HOME/Library/Application Support/monit"
runtime_conf_dir="$runtime_dir/conf.d"
runtime_monitrc="$runtime_dir/monitrc"
local_checks="$runtime_conf_dir/high-cpu-local.monit"
runtime_programs_dir="${XDG_STATE_HOME:-$HOME/.local/state}/monit/programs"
launch_agent="$HOME/Library/LaunchAgents/$label.plist"
notify_script="$repo_dir/no_stow/bin/monit-notify"
scan_script="$repo_dir/no_stow/bin/monit-cpu-scan"
script_path="$repo_dir/no_stow/bin/monit-cpu-alerts"

usage() {
  cat <<'USAGE'
Usage: monit-cpu-alerts <command> [args]

Commands:
  install                         Install runtime Monit config + LaunchAgent plist
  add <name> <regex> [pct] [sec] [cpu|total_cpu]
                                  Add a single-process CPU alert rule (default: 30 60 total_cpu)
  add-scan <name> <regex> [pct] [sec] [cooldown_sec]
                                  Alert when any matching process exceeds CPU for long enough
  load                            Load/restart the LaunchAgent
  unload                          Unload the LaunchAgent
  reload                          Ask Monit to reload config
  test                            Validate the runtime Monit config
  status                          Show Monit status, then launchd status if needed
  procmatch <regex>               Test which processes a Monit regex matches
  edit                            Edit runtime local checks
  paths                           Print important paths

Example:
  monit-cpu-alerts install
  monit-cpu-alerts add ruby-lsp 'ruby-lsp' 30 60 total_cpu
  monit-cpu-alerts add-scan zellij '(^|/)zellij( |$)' 30 30
  monit-cpu-alerts load
USAGE
}

monit_bin() {
  if command -v monit >/dev/null 2>&1; then
    command -v monit
  elif [[ -x /opt/homebrew/bin/monit ]]; then
    print -r -- /opt/homebrew/bin/monit
  elif [[ -x /usr/local/bin/monit ]]; then
    print -r -- /usr/local/bin/monit
  else
    print -u2 "monit is not installed. Run: brew install monit terminal-notifier"
    return 1
  fi
}

render_template() {
  local input=$1 output=$2 mode=$3 monit_path=$4
  local tmp line
  tmp=$(mktemp)
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line//__HOME__/$HOME}"
    line="${line//__RUNTIME_DIR__/$runtime_dir}"
    line="${line//__CONF_DIR__/$runtime_conf_dir}"
    line="${line//__MONIT_BIN__/$monit_path}"
    line="${line//__NOTIFY_SCRIPT__/$notify_script}"
    print -r -- "$line"
  done < "$input" > "$tmp"
  install -m "$mode" "$tmp" "$output"
  rm -f "$tmp"
}

install_config() {
  local monit_path=$1

  mkdir -p "$runtime_conf_dir" "$runtime_dir/events" "$runtime_programs_dir" "$HOME/Library/LaunchAgents" "$HOME/Library/Logs"

  render_template "$source_dir/monitrc" "$runtime_monitrc" 600 "$monit_path"
  render_template "$source_dir/conf.d/high-cpu.monit" "$runtime_conf_dir/high-cpu.monit" 600 "$monit_path"
  render_template "$source_dir/LaunchAgents/$label.plist" "$launch_agent" 644 "$monit_path"

  if [[ ! -f "$local_checks" ]]; then
    cat > "$local_checks" <<EOF
# Local high-CPU process checks generated by monit-cpu-alerts add.
# This file is intentionally runtime-local so Monit's chmod 600 requirement is preserved.
EOF
    chmod 600 "$local_checks"
  fi

  "$monit_path" -t -c "$runtime_monitrc"

  if ! command -v terminal-notifier >/dev/null 2>&1; then
    print -u2 "Warning: terminal-notifier is not installed; notifications will fall back to osascript."
    print -u2 "Install the preferred notifier with: brew install terminal-notifier"
  fi

  print -r -- "Installed Monit CPU alert config."
  print -r -- "Next: add a rule, then run: $script_path load"
}

monit_quote() {
  local s=$1
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  print -r -- "$s"
}

ensure_runtime() {
  local monit_path=$1
  if [[ ! -f "$runtime_monitrc" ]]; then
    install_config "$monit_path"
  fi
}

validate_rule_args() {
  local name=$1 pct=$2 seconds=$3

  if [[ ! "$name" =~ '^[A-Za-z0-9_.-]+$' ]]; then
    print -u2 "Invalid name '$name'. Use letters, numbers, dot, underscore, or dash only."
    return 1
  fi
  if [[ ! "$pct" =~ '^[0-9]+([.][0-9]+)?$' ]]; then
    print -u2 "Invalid CPU percent '$pct'."
    return 1
  fi
  if [[ ! "$seconds" =~ '^[0-9]+$' ]]; then
    print -u2 "Invalid seconds '$seconds'."
    return 1
  fi
}

add_check() {
  local monit_path=$1 name=$2 regex=$3 pct=${4:-30} seconds=${5:-60} kind=${6:-total_cpu}
  local resource cycles escaped_regex escaped_notify backup tmp

  ensure_runtime "$monit_path"
  validate_rule_args "$name" "$pct" "$seconds"

  case "$kind" in
    cpu|self|process) resource="cpu" ;;
    total|total_cpu|total-cpu) resource="total cpu" ;;
    *) print -u2 "Invalid CPU kind '$kind'. Use cpu or total_cpu."; return 1 ;;
  esac

  if grep -Fq "check process $name " "$local_checks"; then
    print -u2 "A check named '$name' already exists in $local_checks"
    return 1
  fi

  cycles=$(( (seconds + poll_seconds - 1) / poll_seconds ))
  escaped_regex=$(monit_quote "$regex")
  escaped_notify=$(monit_quote "$notify_script")

  backup=$(mktemp)
  tmp=$(mktemp)
  cp "$local_checks" "$backup"
  cp "$local_checks" "$tmp"
  cat >> "$tmp" <<EOF

check process $name matching "$escaped_regex"
  mode passive
  if $resource > $pct% for $cycles cycles then exec "$escaped_notify"
EOF
  install -m 600 "$tmp" "$local_checks"
  rm -f "$tmp"

  if ! "$monit_path" -t -c "$runtime_monitrc"; then
    install -m 600 "$backup" "$local_checks"
    rm -f "$backup"
    print -u2 "Config test failed; restored $local_checks"
    return 1
  fi
  rm -f "$backup"

  print -r -- "Added '$name': regex='$regex', threshold=${pct}% for ${seconds}s (${cycles} cycles), kind=$kind"
  print -r -- "Test matches with: $script_path procmatch '$regex'"
  print -r -- "Apply to running Monit with: $script_path reload"
}

shell_quote() {
  printf '%q' "$1"
}

add_scan() {
  local monit_path=$1 name=$2 regex=$3 pct=${4:-30} seconds=${5:-60} cooldown=${6:-300}
  local backup tmp wrapper escaped_wrapper quoted_scan quoted_name quoted_regex quoted_pct quoted_seconds quoted_cooldown

  ensure_runtime "$monit_path"
  validate_rule_args "$name" "$pct" "$seconds"

  if [[ ! "$cooldown" =~ '^[0-9]+$' ]]; then
    print -u2 "Invalid cooldown seconds '$cooldown'."
    return 1
  fi
  if grep -Fq "check program $name " "$local_checks"; then
    print -u2 "A program check named '$name' already exists in $local_checks"
    return 1
  fi

  mkdir -p "$runtime_programs_dir"
  wrapper="$runtime_programs_dir/$name-cpu-scan"
  quoted_scan=$(shell_quote "$scan_script")
  quoted_name=$(shell_quote "$name")
  quoted_regex=$(shell_quote "$regex")
  quoted_pct=$(shell_quote "$pct")
  quoted_seconds=$(shell_quote "$seconds")
  quoted_cooldown=$(shell_quote "$cooldown")

  cat > "$wrapper" <<EOF
#!/bin/zsh
export STOW_DIR=$(shell_quote "$repo_dir")
exec $quoted_scan $quoted_name $quoted_regex $quoted_pct $quoted_seconds $quoted_cooldown
EOF
  chmod 700 "$wrapper"

  escaped_wrapper=$(monit_quote "$wrapper")
  backup=$(mktemp)
  tmp=$(mktemp)
  cp "$local_checks" "$backup"
  cp "$local_checks" "$tmp"
  cat >> "$tmp" <<EOF

check program $name with path "$escaped_wrapper"
  if status != 0 then alert
EOF
  install -m 600 "$tmp" "$local_checks"
  rm -f "$tmp"

  if ! "$monit_path" -t -c "$runtime_monitrc"; then
    install -m 600 "$backup" "$local_checks"
    rm -f "$backup" "$wrapper"
    print -u2 "Config test failed; restored $local_checks"
    return 1
  fi
  rm -f "$backup"

  print -r -- "Added scan '$name': regex='$regex', threshold=${pct}% for ${seconds}s, cooldown=${cooldown}s"
  print -r -- "Apply to running Monit with: $script_path reload"
}

load_agent() {
  local domain="gui/$(id -u)"
  launchctl bootout "$domain" "$launch_agent" >/dev/null 2>&1 || true
  launchctl bootstrap "$domain" "$launch_agent"
  launchctl kickstart -k "$domain/$label"
  print -r -- "Loaded $label"
}

unload_agent() {
  local domain="gui/$(id -u)"
  launchctl bootout "$domain" "$launch_agent" || true
}

cmd=${1:-}
if [[ -z "$cmd" ]]; then
  usage
  exit 1
fi
shift || true

case "$cmd" in
  install)
    install_config "$(monit_bin)"
    ;;
  add)
    if (( $# < 2 )); then usage; exit 1; fi
    add_check "$(monit_bin)" "$@"
    ;;
  add-scan)
    if (( $# < 2 )); then usage; exit 1; fi
    add_scan "$(monit_bin)" "$@"
    ;;
  load)
    monit_path=$(monit_bin)
    ensure_runtime "$monit_path"
    load_agent
    ;;
  unload)
    unload_agent
    ;;
  reload)
    monit_path=$(monit_bin)
    ensure_runtime "$monit_path"
    "$monit_path" -c "$runtime_monitrc" reload
    ;;
  test)
    monit_path=$(monit_bin)
    ensure_runtime "$monit_path"
    "$monit_path" -t -c "$runtime_monitrc"
    ;;
  status)
    monit_path=$(monit_bin)
    ensure_runtime "$monit_path"
    "$monit_path" -c "$runtime_monitrc" status || launchctl print "gui/$(id -u)/$label"
    ;;
  procmatch)
    if (( $# != 1 )); then usage; exit 1; fi
    "$(monit_bin)" procmatch "$1"
    ;;
  edit)
    ensure_runtime "$(monit_bin)"
    "${EDITOR:-nvim}" "$local_checks"
    ;;
  paths)
    cat <<EOF
runtime_monitrc=$runtime_monitrc
runtime_checks=$local_checks
launch_agent=$launch_agent
notify_script=$notify_script
scan_script=$scan_script
monit_log=$HOME/Library/Logs/monit.log
notify_log=$HOME/Library/Logs/monit-notify.log
scan_log=$HOME/Library/Logs/monit-cpu-scan.log
launchd_stdout=$HOME/Library/Logs/monit-launchd.out.log
launchd_stderr=$HOME/Library/Logs/monit-launchd.err.log
EOF
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    usage
    exit 1
    ;;
esac
