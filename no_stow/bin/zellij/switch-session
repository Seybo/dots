#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/zellij"
STATE_FILE="$STATE_DIR/last-session"
TAB_STATE_DIR="$STATE_DIR/session-tabs"
mkdir -p "$TAB_STATE_DIR"

usage() {
  cat <<'EOF'
Usage:
  zellij-switch-session to <session-name>
  zellij-switch-session last
EOF
}

current_session() {
  if [[ -n "${ZELLIJ_SESSION_NAME:-}" ]]; then
    printf '%s\n' "$ZELLIJ_SESSION_NAME"
    return 0
  fi

  return 1
}

current_tab_position() {
  zellij action current-tab-info 2>/dev/null | awk -F': ' '$1 == "position" { print $2; exit }'
}

tab_state_file() {
  local session="$1"
  printf '%s/%s\n' "$TAB_STATE_DIR" "${session//\//_}"
}

normalize_session_name() {
  local session="$1"

  case "$session" in
    system)
      printf '%s\n' "shaka1"
      ;;
    gtm)
      printf '%s\n' "shaka2"
      ;;
    *)
      printf '%s\n' "$session"
      ;;
  esac
}

active_session_exists() {
  local session="$1"

  zellij list-sessions --short --no-formatting 2>/dev/null | grep -Fx -- "$session" >/dev/null
}

remember_current_tab() {
  local current="$1"
  local position

  if [[ -z "$current" ]]; then
    return 0
  fi

  position="$(current_tab_position || true)"
  if [[ "$position" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "$position" > "$(tab_state_file "$current")"
  fi
}

switch_to() {
  local target="$1"
  local current="${2:-}"
  local target_tab_file
  local target_tab_position=""

  if [[ -n "$current" && "$current" != "$target" ]]; then
    printf '%s\n' "$current" > "$STATE_FILE"
    remember_current_tab "$current"
  fi

  target_tab_file="$(tab_state_file "$target")"
  if [[ -f "$target_tab_file" ]]; then
    target_tab_position="$(<"$target_tab_file")"
  fi

  if [[ "$target_tab_position" =~ ^[0-9]+$ ]]; then
    # current-tab-info reports zero-based positions, but switch-session --tab-position
    # expects one-based positions.
    exec zellij action switch-session --tab-position "$((target_tab_position + 1))" "$target"
  fi

  exec zellij action switch-session "$target"
}

cmd="${1:-}"

case "$cmd" in
  to)
    target="${2:-}"
    if [[ -z "$target" ]]; then
      usage
      exit 1
    fi

    current="$(current_session || true)"
    switch_to "$target" "$current"
    ;;
  last)
    if [[ ! -f "$STATE_FILE" ]]; then
      echo "No last session recorded" >&2
      exit 1
    fi

    last="$(normalize_session_name "$(<"$STATE_FILE")")"
    if [[ -z "$last" ]]; then
      echo "No last session recorded" >&2
      exit 1
    fi

    if ! active_session_exists "$last"; then
      echo "Last session is not active: $last" >&2
      exit 1
    fi

    current="$(current_session || true)"
    if [[ -n "$current" && "$current" == "$last" ]]; then
      echo "Already in last session" >&2
      exit 1
    fi

    switch_to "$last" "$current"
    ;;
  *)
    usage
    exit 1
    ;;
esac
