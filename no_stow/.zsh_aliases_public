alias re_tmux='tmux source-file $STOW_DIR/.tmux.conf'
pwdc() {
  local current_path
  current_path="$(builtin pwd "$@")" || return
  print -r -- "$current_path"
  print -rn -- "$current_path" | pbcopy
}
theme() {
  ruby ~/.dots/themes/theme_switcher.rb "$@"
  if command -v tmux >/dev/null 2>&1 && tmux info >/dev/null 2>&1; then
    tmux source-file "$STOW_DIR/.tmux.conf"
  fi
  if [ "$TERM_PROGRAM" = "ghostty" ]; then
    echo "ghostty: press cmd+shift+, to reload config"
  fi
  re_fzf
}


### tmux ###
alias tksv='tmux kill-server'
alias tkss='tmux kill-session -t'
mux() {
  local workspace_launcher="${STOW_DIR:-$HOME/.dots}/no_stow/bin/tmux/start-workspace"
  local target="${1:-}"

  if [[ $# -eq 1 ]] && [[ -x "$workspace_launcher" ]] && "$workspace_launcher" --check "$target"; then
    if ! tmux has-session -t "$target" 2>/dev/null; then
      "$workspace_launcher" "$target" || return
    fi

    if [[ -n "${TMUX:-}" ]]; then
      tmux switch-client -t "$target"
    else
      tmux attach-session -t "$target"
    fi
    return
  fi

  command tmuxinator "$@"
}

### zellij ###
zj() {
  local name="$1"

  if [ -z "$name" ]; then
    echo "usage: zj <session/layout>"
    return 1
  fi

  if zellij list-sessions --short --no-formatting 2>/dev/null | grep -Fxq "$name"; then
    zellij attach "$name"
  else
    zellij --new-session-with-layout "$name" -s "$name"
  fi
}
# Force Zellij top bar to repaint when it stays stale after theme switching.
retheme() {
  "$STOW_DIR/no_stow/bin/zellij/retheme"
  re_fzf
}


