### AI agents ###
_agent_attention_notify_for_current_tmux_pane() {
  local watcher="$STOW_DIR/no_stow/bin/tmux/agent-attention-notify"

  if [ -n "${TMUX:-}" ] && [ -n "${TMUX_PANE:-}" ] && [ -x "$watcher" ]; then
    pkill -f "agent-attention-notify --pane $TMUX_PANE" >/dev/null 2>&1 || true
    "$watcher" --pane "$TMUX_PANE" >/dev/null 2>&1 &!
  fi
}

_run_with_agent_attention() {
  local agent_command="$1"
  local watcher="$STOW_DIR/no_stow/bin/tmux/agent-attention-notify"
  local exit_status
  shift

  _agent_attention_notify_for_current_tmux_pane
  if [ -n "${TMUX:-}" ] && [ -n "${TMUX_PANE:-}" ] && [ -x "$watcher" ]; then
    "$watcher" --agent-start "$TMUX_PANE" >/dev/null 2>&1 || true
  fi

  # Run the agent in a child shell so interrupt/term signals return here for cleanup.
  (
    trap 'exit 130' INT
    trap 'exit 143' TERM
    trap 'exit 129' HUP
    command "$agent_command" "$@"
  )
  exit_status=$?

  if [ -n "${TMUX:-}" ] && [ -n "${TMUX_PANE:-}" ] && [ -x "$watcher" ]; then
    "$watcher" --agent-stop "$TMUX_PANE" >/dev/null 2>&1 || true
  fi

  return "$exit_status"
}

claude() {
  _run_with_agent_attention claude "$@"
}

pi-p() {
  PI_CODING_AGENT_DIR="$HOME/.pi/personal" \
  PI_CODING_AGENT_SESSION_DIR="$HOME/.pi/personal/agent/sessions" \
