### console general ###
alias ll='ls -al -G'
alias ..='cd ..'
alias brew_update_all='brew update && brew upgrade && brew upgrade --cask && brew cleanup'
alias re_source='source ~/.zshrc'
alias re_fzf='source $STOW_DIR/themes/active/fzf.zsh'
alias re_tmux='tmux source-file $STOW_DIR/.tmux.conf'
theme() {
  ruby ~/.dots/themes/theme_switcher.rb "$@"
  if command -v tmux >/dev/null 2>&1 && tmux info >/dev/null 2>&1; then
    tmux source-file "$STOW_DIR/.tmux.conf"
  fi
  if [ "$TERM_PROGRAM" = "ghostty" ]; then
    echo "ghostty: press cmd+shift+, to reload config"
  fi
  re_fzf
}


### tmux ###
alias tksv='tmux kill-server'
alias tkss='tmux kill-session -t'
alias mux='tmuxinator'

### zellij ###
alias zscs='zellij --new-session-with-layout system -s system'
alias zsas='zellij attach system'
alias zsch='zellij --new-session-with-layout help -s help'
alias zsah='zellij attach help'
alias zsct='zellij -c temp'
alias zsct='zellij --new-session-with-layout default -s temp'
alias zsat='zellij attach temp'
alias zscg='zellij --new-session-with-layout gtm -s gtm'
alias zsag='zellij attach gtm'
alias zsck='zellij --new-session-with-layout kaamp -s kaamp'
alias zsak='zellij attach kaamp'
alias zscr='zellij --new-session-with-layout remote_dev -s remote_dev'
alias zsar='zellij attach remote_dev'
# Force Zellij top bar to repaint when it stays stale after theme switching.
retheme() {
  "$STOW_DIR/no_stow/bin/zellij/retheme"
  re_fzf
}


### git ###
alias lg='lazygit'
alias gca='git commit -n --amend'
alias gca!='git commit -n --amend --no-edit'
alias gitc='git commit -n -v -m'
alias gstt='git stash save temp'
alias gc-='git checkout -'
alias gro='git rebase --onto'
alias grs1='git reset --soft HEAD~1' # revert last commit
alias grsa='git reset --soft HEAD@{1}' # revert amend
alias gitct='gitc "temp"'
alias gsta='git stash save' # overwriting oh-my-zsh that uses git stash push
alias gstt='git stash save temp'


### stow ###
alias stow_check="cd $STOW_DIR && stow -n -v ."
alias stow_do="cd $STOW_DIR && stow -v ."


### rails ###
