// Extracted from upstream Nightfox Zellij theme and renamed to `active`.
// Upstream: https://github.com/EdenEast/nightfox.nvim/raw/main/extra/zellij/nightfox.kdl

themes {
  active {
    bg "#3e4a5b"
    fg "#cdcecf"
    red "#bf616a"
    green "#a3be8c"
    blue "#81a1c1"
    yellow "#ebcb8b"
    magenta "#b48ead"
    orange "#c9826b"
    cyan "#88c0d0"
    black "#444c5e"
    white "#abb1bb"
  }
}
