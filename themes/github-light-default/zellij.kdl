// No upstream Zellij theme exists in projekt0n/github-nvim-theme.
// Values below are extracted from its github_light_default palette/primitives and mapped to Zellij's simple color keys.
// Sources:
// - https://github.com/projekt0n/github-nvim-theme/raw/main/lua/github-theme/palette/github_light_default.lua
// - https://github.com/projekt0n/github-nvim-theme/raw/main/lua/github-theme/palette/primitives/light.lua

themes {
  active {
    bg "#ffffff"
    fg "#1F2328"
    red "#cf222e"
    green "#116329"
    blue "#0969da"
    yellow "#9a6700"
    magenta "#8250df"
    orange "#bc4c00"
    cyan "#1b7c83"
    black "#24292f"
    white "#d0d7de"
  }
}
